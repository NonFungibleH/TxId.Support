# Anthropic
ANTHROPIC_API_KEY=

# Voyage AI (embeddings — https://www.voyageai.com/)
VOYAGE_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Note: redirect URLs after sign-in/sign-up are set as props on <ClerkProvider> in layout.tsx
# Do NOT add NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL / AFTER_SIGN_UP_URL — deprecated in Clerk v5

# Blockchain
MORALIS_API_KEY=
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
BSCSCAN_API_KEY=

# DexScreener — no key required (public API)

# Marketing site live widget (set to a publishable key to activate the widget on txid.support)
# Create a "TxID Support" demo project in the dashboard and paste its pk_ key here
NEXT_PUBLIC_DEMO_WIDGET_KEY=

# App URLs (local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_DOCS_URL=http://localhost:3002
NEXT_PUBLIC_WIDGET_URL=http://localhost:3003
